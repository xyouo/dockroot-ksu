# 是否在开机后启动 autostart.list 中的容器：1=启用，0=停用
AUTO_START=1

# 等待 Android 完成开机的最长秒数
BOOT_WAIT=120

# DockRoot 数据目录。不要放在 /sdcard 等共享存储中
DATA_ROOT=/data/adb/dockroot/data

# 仅供 DockRoot 独立网络环境使用，不修改 Android 系统 DNS
DNS_SERVERS=223.5.5.5 1.1.1.1

# 停止旧进程和等待新容器健康的超时时间（秒）
STOP_TIMEOUT=15
START_TIMEOUT=30

# 模块与容器启动日志超过该大小后轮转，单位 KiB
MAX_LOG_SIZE_KB=1024
